diff -ruN currentbase-canonical/scripts/tests/world_smoke.gd canonical-v3/scripts/tests/world_smoke.gd
--- currentbase-canonical/scripts/tests/world_smoke.gd	1970-01-01 00:00:00.000000000 +0000
+++ canonical-v3/scripts/tests/world_smoke.gd	2026-07-16 03:15:54.726924094 +0000
@@ -0,0 +1,60 @@
+extends SceneTree
+
+const WorldRuntimeScript = preload("res://scripts/world/world_runtime.gd")
+const Blocks = preload("res://scripts/world/block_registry.gd")
+
+const TEST_TIMEOUT_MSEC := 90000
+const TEST_SEED := 125381066
+
+
+func _initialize() -> void:
+	_run.call_deferred()
+
+
+func _run() -> void:
+	var runtime = WorldRuntimeScript.new()
+	runtime.configure("CI V3 Surface Test", "ci_v3_surface_test", TEST_SEED)
+	root.add_child(runtime)
+
+	var timeout_at := Time.get_ticks_msec() + TEST_TIMEOUT_MSEC
+	while not bool(runtime.get("_world_ready")) and Time.get_ticks_msec() < timeout_at:
+		await process_frame
+
+	if not bool(runtime.get("_world_ready")):
+		_fail("World did not finish meshing spawn chunks before timeout")
+		return
+
+	var snapshot: Dictionary = runtime.call("get_validation_snapshot")
+	var spawn: Vector3 = snapshot.get("spawn", Vector3.ZERO)
+	var surface := int(snapshot.get("surface", -9999))
+	var sea_level := int(snapshot.get("sea_level", 9999))
+	var floor_block := int(snapshot.get("floor_block", Blocks.AIR))
+	var head_block := int(snapshot.get("head_block", Blocks.AIR))
+
+	if spawn.y < float(surface) + 0.8 or spawn.y > float(surface) + 4.5:
+		_fail("Unsafe spawn height: spawn=%s surface=%d" % [spawn, surface])
+		return
+	if surface <= sea_level + 2:
+		_fail("Spawn selected ocean/beach elevation: surface=%d sea=%d" % [surface, sea_level])
+		return
+	if floor_block in [Blocks.AIR, Blocks.WATER]:
+		_fail("Spawn floor is not solid: block=%d" % floor_block)
+		return
+	if head_block != Blocks.AIR:
+		_fail("Spawn head space is obstructed: block=%d" % head_block)
+		return
+
+	print(
+		(
+			"VOXELCRAFT_WORLD_SMOKE_OK spawn=%s surface=%d sea=%d biome=%d floor=%d"
+			% [spawn, surface, sea_level, int(snapshot.get("biome", -1)), floor_block]
+		)
+	)
+	runtime.queue_free()
+	await process_frame
+	quit(0)
+
+
+func _fail(message: String) -> void:
+	push_error("VOXELCRAFT_WORLD_SMOKE_FAIL: %s" % message)
+	quit(1)
