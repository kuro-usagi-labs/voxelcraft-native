+func get_validation_snapshot() -> Dictionary:
+	if generator == null or player == null or terrain == null:
+		return {"ready": false}
+	var x := floori(player.global_position.x)
+	var z := floori(player.global_position.z)
+	var surface := int(generator.call("get_surface_height", x, z))
+	var sea_level := int(generator.call("get_sea_level"))
+	var biome := int(generator.call("get_biome", x, z, surface))
+	var voxel_tool = terrain.call("get_voxel_tool")
+	voxel_tool.set("channel", 0)
+	var floor_block := int(voxel_tool.call("get_voxel", Vector3i(x, surface, z)))
+	var head_block := int(voxel_tool.call("get_voxel", Vector3i(x, surface + 2, z)))
+	return {
+		"ready": _world_ready,
+		"spawn": player.global_position,
+		"surface": surface,
+		"sea_level": sea_level,
+		"biome": biome,
+		"floor_block": floor_block,
+		"head_block": head_block,
+	}
